package herencia;

public abstract class Vehiculo {
	private String modelo;
	private String nroMotor;
	private String color;
	private int cantRuedas;
	
	
	public void setmodelo(String a) {
		this.modelo=a;
	}
	public String getmodelo() {
		return modelo;
	}
	public void setnroMotor(String b) {
		this.modelo=b;
	}
	public String getnromotor() {
		return nroMotor;
	}
	public void setcolor(String c) {
		this.color=c;
	}
	public String getcolor() {
		return color;
	}
	public void setcantRuedas(int d) {
		this.cantRuedas=d;
	}
	public int getcantRuedas() {
		return cantRuedas;
	}
	public Vehiculo (String a, String b, String c) {
		this.modelo=a;
		this.nroMotor=b;
		this.color=c;
}
}



