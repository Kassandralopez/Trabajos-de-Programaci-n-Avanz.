	public static void ModificarLibro(Libro[]ar, int codigoActual, int datoAModif, int a, String m) {
		System.out.println("Codigo:");
		for (int i=0;i<ar.length;i++) {
			if (ar[i]!=null && ar[i].codigoUnico()==m) {
			if(i==1 && !chequearExistenciaLibro(m,ar))
					ar[i].setcodigoUnico(m);
			}else {
				ar[i].setAutor(m);
			
			}
		}																													
	}

	public static boolean chequearExistenciaLibro(String codigoUnico,Libro[]ar) {
		boolean existe=false;
		
		for (int i=0;i<ar.length;i++) {
			if (ar[i] !=null && ar[i].codigoUnico()==codigoUnico) {
					existe=true;
					System.out.println("Ya existe un libro con ese codigo");
						break;
			}
		}
		return existe;
	}
				
			
		
	

